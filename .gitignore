# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Next.js cache ─────────────────────────────────────────────────────────────
.next/cache/

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Supabase local dev ────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp

# ── Test output ───────────────────────────────────────────────────────────────
coverage/
*.lcov

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor artifacts ──────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
